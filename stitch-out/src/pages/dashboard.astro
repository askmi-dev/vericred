---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Connections Dashboard">
    <!-- Top Header -->
    <div class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight">Connections Dashboard</h2>
        <p class="text-slate-400 text-sm md:text-base mt-1">Manage your organization's decentralized identity roots, revocation lists, and database connectors.</p>
    </div>

    <!-- KPI Cards Grid (4 Columns) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- KPI 1 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-5 flex flex-col justify-between hover:border-emerald-500/20 transition-all">
            <span class="text-xs font-mono text-slate-500 uppercase tracking-wider flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-emerald-500 text-base">verified</span>
                Total Issued
            </span>
            <div>
                <span class="text-3xl font-extrabold text-white">42,891</span>
                <span class="text-xs font-mono text-emerald-500 block mt-1">+12.4% this month</span>
            </div>
        </div>

        <!-- KPI 2 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-5 flex flex-col justify-between hover:border-emerald-500/20 transition-all">
            <span class="text-xs font-mono text-slate-500 uppercase tracking-wider flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-purple-400 text-base">rule</span>
                Revocation Lists
            </span>
            <div>
                <span class="text-3xl font-extrabold text-white">2 <span class="text-xs font-mono text-slate-400 font-normal">Active</span></span>
                <span class="text-xs font-mono text-slate-500 block mt-1">StatusList2021 format</span>
            </div>
        </div>

        <!-- KPI 3 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-5 flex flex-col justify-between hover:border-emerald-500/20 transition-all">
            <span class="text-xs font-mono text-slate-500 uppercase tracking-wider flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-blue-400 text-base">history</span>
                Last Issuance
            </span>
            <div>
                <span class="text-3xl font-extrabold text-white">2 <span class="text-xs font-mono text-slate-400 font-normal">mins ago</span></span>
                <span class="text-xs font-mono text-slate-500 block mt-1">UniversityDegree type</span>
            </div>
        </div>

        <!-- KPI 4 -->
        <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-5 flex flex-col justify-between hover:border-emerald-500/20 transition-all">
            <span class="text-xs font-mono text-slate-500 uppercase tracking-wider flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-emerald-400 text-base">wifi_tethering</span>
                Gateway Status
            </span>
            <div>
                <span class="text-3xl font-extrabold text-white text-emerald-400">ACTIVE</span>
                <span class="text-xs font-mono text-slate-500 block mt-1">Node Port: 3100 (SSL)</span>
            </div>
        </div>
    </div>

    <!-- Identity & Database Connectors Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-8">
        <!-- Issuer Identity (8 columns) -->
        <div class="lg:col-span-8 bg-slate-900/60 border border-slate-800/80 rounded-2xl p-6 flex flex-col justify-between">
            <div>
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
                        <span class="material-symbols-outlined text-emerald-500 text-lg">admin_panel_settings</span>
                        Primary Issuer Identity
                    </h3>
                    <span class="text-[10px] font-mono font-semibold text-blue-400 bg-blue-500/10 border border-blue-500/20 px-2.5 py-1 rounded-full uppercase tracking-wider">
                        Public Domain Web ID
                    </span>
                </div>
                <p class="text-slate-400 text-sm mb-6 leading-relaxed">
                    This is your primary cryptographically verifiable public issuer key. All credentials issued by VeriCred are signed using this decentralized identifier (DID), allowing OID4VCI wallets to resolve and verify trust parameters directly over HTTPS.
                </p>
            </div>
            
            <div class="bg-slate-950 rounded-xl p-4 border border-slate-800 flex justify-between items-center group">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-slate-600 text-xl">vpn_key</span>
                    <code id="dashboard-did-code" class="font-mono text-sm text-slate-200 select-all break-all">did:web:vericred.dev</code>
                </div>
                <button id="copy-did-dashboard-btn" class="text-slate-400 hover:text-emerald-400 transition-colors p-1" title="Copy DID to Clipboard">
                    <span class="material-symbols-outlined text-lg">content_copy</span>
                </button>
            </div>
        </div>

        <!-- Database Connectors (4 columns) -->
        <div class="lg:col-span-4 bg-slate-900/60 border border-slate-800/80 rounded-2xl flex flex-col overflow-hidden">
            <div class="p-5 border-b border-slate-800/80 bg-slate-900/20">
                <h3 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
                    <span class="material-symbols-outlined text-emerald-500 text-lg font-bold">database</span>
                    Active Connectors
                </h3>
            </div>
            
            <div class="flex-grow flex flex-col divide-y divide-slate-800/50">
                <!-- Connector 1 -->
                <div class="p-4 flex items-center justify-between hover:bg-slate-800/20 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-slate-950 border border-slate-800 flex items-center justify-center text-slate-300">
                            <span class="material-symbols-outlined text-lg">storage</span>
                        </div>
                        <div>
                            <p class="text-xs font-mono font-bold text-white uppercase">PostgreSQL Database</p>
                            <p class="text-[10px] font-mono text-slate-500 mt-0.5">Pool: 15 active • Latency: 25ms</p>
                        </div>
                    </div>
                    <span class="flex h-2.5 w-2.5 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500" title="Connected"></span>
                    </span>
                </div>

                <!-- Connector 2 -->
                <div class="p-4 flex items-center justify-between hover:bg-slate-800/20 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-slate-950 border border-slate-800 flex items-center justify-center text-slate-300">
                            <span class="material-symbols-outlined text-lg">api</span>
                        </div>
                        <div>
                            <p class="text-xs font-mono font-bold text-white uppercase">REST Intake API</p>
                            <p class="text-[10px] font-mono text-slate-500 mt-0.5">Bearer Token • OAuth2 verified</p>
                        </div>
                    </div>
                    <span class="flex h-2.5 w-2.5 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500" title="Connected"></span>
                    </span>
                </div>

                <!-- Connector 3 (Inactive) -->
                <div class="p-4 flex items-center justify-between hover:bg-slate-800/20 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-slate-950 border border-slate-800 flex items-center justify-center text-slate-500">
                            <span class="material-symbols-outlined text-lg">cloud_sync</span>
                        </div>
                        <div>
                            <p class="text-xs font-mono font-bold text-slate-500 uppercase">Google Sheets Sync</p>
                            <p class="text-[10px] font-mono text-slate-500 mt-0.5">Not configured</p>
                        </div>
                    </div>
                    <span class="inline-flex rounded-full h-2.5 w-2.5 bg-slate-700" title="Disconnected"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Issuer Logs Panel -->
    <div class="bg-slate-900/60 border border-slate-800/80 rounded-2xl p-6">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-white tracking-tight flex items-center gap-2">
                <span class="material-symbols-outlined text-emerald-500 text-lg">history_edu</span>
                Recent Gateway Transactions
            </h3>
            <a href="/monitor" class="text-xs font-mono text-slate-400 hover:text-emerald-400 transition-colors flex items-center gap-1.5">
                <span>View Full Log</span>
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>
        
        <div class="overflow-x-auto custom-scrollbar border border-slate-800/50 rounded-xl">
            <table class="w-full text-left border-collapse font-mono text-xs">
                <thead>
                    <tr class="border-b border-slate-800 bg-slate-950/40 text-slate-500 uppercase font-semibold text-[10px] tracking-wider">
                        <th class="p-4">Transaction ID</th>
                        <th class="p-4">Timestamp</th>
                        <th class="p-4">Subject DID</th>
                        <th class="p-4">Credential Schema</th>
                        <th class="p-4">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50 text-slate-300">
                    <tr class="hover:bg-slate-800/10">
                        <td class="p-4 text-slate-400">tx_8a93d2c1e7</td>
                        <td class="p-4">2026-06-04 03:41:20</td>
                        <td class="p-4 text-emerald-400">did:key:z6MkuSccD1L...</td>
                        <td class="p-4">UniversityDegree</td>
                        <td class="p-4">
                            <span class="px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full font-bold uppercase text-[9px] tracking-wider">Success</span>
                        </td>
                    </tr>
                    <tr class="hover:bg-slate-800/10">
                        <td class="p-4 text-slate-400">tx_7c23f1a9b2</td>
                        <td class="p-4">2026-06-04 03:38:05</td>
                        <td class="p-4 text-emerald-400">did:key:z6MkjAa38bN...</td>
                        <td class="p-4">UniversityDegree</td>
                        <td class="p-4">
                            <span class="px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full font-bold uppercase text-[9px] tracking-wider">Success</span>
                        </td>
                    </tr>
                    <tr class="hover:bg-slate-800/10">
                        <td class="p-4 text-slate-400">tx_2b90c1f5e8</td>
                        <td class="p-4">2026-06-04 03:30:12</td>
                        <td class="p-4 text-emerald-400">did:key:z6MkpZ78cY3...</td>
                        <td class="p-4">EmploymentCredential</td>
                        <td class="p-4">
                            <span class="px-2 py-0.5 bg-red-500/10 border border-red-500/20 text-red-400 rounded-full font-bold uppercase text-[9px] tracking-wider">Failed</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Client Clipboard Script for Dashboard -->
    <script is:inline>
        const copyDashboardBtn = document.getElementById('copy-did-dashboard-btn');
        const codeDashboardEl = document.getElementById('dashboard-did-code');
        const dToast = document.getElementById('toast');
        const dToastMsg = document.getElementById('toast-message');

        if (copyDashboardBtn && codeDashboardEl && dToast && dToastMsg) {
            copyDashboardBtn.addEventListener('click', () => {
                navigator.clipboard.writeText(codeDashboardEl.textContent).then(() => {
                    dToastMsg.textContent = 'Issuer DID copied to clipboard!';
                    dToast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
                    dToast.classList.add('opacity-100', 'translate-y-0');
                    setTimeout(() => {
                        dToast.classList.remove('opacity-100', 'translate-y-0');
                        dToast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
                    }, 3000);
                });
            });
        }
    </script>
</AdminLayout>
