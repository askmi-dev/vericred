---
// VeriCred Public Landingpage
---

<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>VeriCred | Verifiable Credentials Gateway</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link href="/assets/a39f5c6fcbb87b419667ec984d2e579a.css" rel="stylesheet" />
    <!-- Tailwind Runtime Compiler -->
    <script src="/assets/03ba5d9f9e95fc3599acebcbe7e5fb9a.js" is:inline></script>
    <script id="tailwind-config" is:inline>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: "#ecfdf5",
                            500: "#10b981",
                            600: "#059669",
                            900: "#064e3b"
                        },
                        slate: {
                            800: "#1e293b",
                            900: "#0f172a",
                            950: "#020617"
                        }
                    },
                    fontFamily: {
                        sans: ["Outfit", "sans-serif"],
                        mono: ["JetBrains Mono", "monospace"]
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #faf9f6;
            background-image: 
                radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(245, 158, 11, 0.04) 0px, transparent 50%);
            color: #1e293b;
        }
        .grid-bg {
            background-size: 40px 40px;
            background-image: linear-gradient(to right, rgba(15, 23, 42, 0.015) 1px, transparent 1px),
                              linear-gradient(to bottom, rgba(15, 23, 42, 0.015) 1px, transparent 1px);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.02);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            border-color: rgba(16, 185, 129, 0.15);
            box-shadow: 0 12px 36px rgba(16, 185, 129, 0.05);
            transform: translateY(-2px);
        }
        .code-block {
            font-family: 'JetBrains Mono', monospace;
            background: rgba(248, 250, 252, 0.85);
            border: 1px solid rgba(0, 0, 0, 0.04);
        }
    </style>
</head>
<body class="min-h-screen text-slate-700 antialiased flex flex-col grid-bg">

    <!-- Top Navigation Header -->
    <header class="border-b border-slate-100 bg-white/60 backdrop-blur-md sticky top-0 z-40">
        <div class="flex justify-between items-center h-16 px-6 max-w-7xl mx-auto w-full relative">
            <div class="flex items-center gap-3">
                <svg width="36" height="32" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="drop-shadow-[0_2px_8px_rgba(16,185,129,0.15)]">
                    <rect width="200" height="200" rx="40" fill="#1C1917" />
                    <path d="M60 70L100 140L140 70" stroke="#10B981" stroke-width="20" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M100 140L160 50" stroke="#10B981" stroke-width="20" stroke-linecap="round" stroke-linejoin="round" opacity="0.8" />
                    <circle cx="100" cy="100" r="10" fill="#F8FAFC" />
                </svg>
                <span id="nav-brand-name" class="text-xl font-bold tracking-tight text-slate-900">VeriCred</span>
            </div>
            
            <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-500">
                <a class="hover:text-slate-950 transition-colors" href="/dev/navigator">Library</a>
                <a class="hover:text-slate-950 transition-colors" href="/walkthrough.md" target="_blank">Documentation</a>
            </nav>

            <div class="flex items-center gap-4">
                <a href="/console/dashboard" class="bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-600 border border-emerald-500/20 font-semibold px-4 py-2 rounded-xl transition-all flex items-center gap-2 text-sm">
                    <span id="nav-cta-text">Gateway Console</span>
                    <span class="material-symbols-outlined text-sm">settings_input_component</span>
                </a>
            </div>
        </div>
    </header>

    <!-- Main Hero Body -->
    <main class="flex-grow flex flex-col items-center justify-center py-20 px-6 max-w-5xl mx-auto w-full relative">
        
        <!-- Hero badge -->
        <div class="text-center mb-16 relative z-10">
            <div id="hero-badge" class="inline-flex items-center gap-2 px-3.5 py-1 bg-emerald-500/10 border border-emerald-500/15 rounded-full text-emerald-600 font-mono text-xs font-semibold uppercase tracking-wider mb-8">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" />
                v2.1.0 open-source production release
            </div>
            
            <h1 id="hero-title" class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-900 mb-6 leading-tight max-w-4xl mx-auto">
                Verifiable Credentials schnell aus bestehenden Datenquellen ausstellen.
            </h1>
            
            <p id="hero-desc" class="text-slate-500 text-lg md:text-xl mb-10 max-w-3xl mx-auto leading-relaxed">
                Verbinden Sie Ihre SQL-Datenbanken, PostgreSQL-Datastores oder REST-APIs direkt mit dem EU-Wallet-Ökosystem. 
                Keine Blockchain, keine künstliche Komplexität. Reines OID4VCI & SD-JWT-VC Gateway-Issuance.
            </p>

            <div id="hero-ctas" class="flex flex-col sm:flex-row items-center justify-center gap-4">
               <a id="cta-primary" href="/console/dashboard" class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-8 py-4 rounded-xl flex items-center justify-center gap-2 transition-all shadow-[0_4px_20px_rgba(16,185,129,0.15)]">
                   <span>Open Gateway Console</span>
                   <span class="material-symbols-outlined text-lg">settings_input_component</span>
               </a>
               <a id="cta-secondary" href="/docs/WALLET_INTEROP_GUIDE.md" target="_blank" class="w-full sm:w-auto bg-white border border-slate-200 text-slate-600 hover:text-slate-900 font-bold px-8 py-4 rounded-xl flex items-center justify-center gap-2 hover:bg-slate-50/50 transition-all shadow-sm">
                   <span class="material-symbols-outlined text-lg">smartphone</span>
                   <span>Connect Real Wallet</span>
               </a>
            </div>

            <!-- Issuer Info (Initially Hidden) -->
            <div id="issuer-info-card" class="hidden mt-12 bg-slate-950 rounded-2xl p-4 border border-slate-800 inline-flex items-center gap-4 animate-in fade-in slide-in-from-bottom-4 duration-700">
                <div class="w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500 border border-emerald-500/20">
                    <span class="material-symbols-outlined">verified</span>
                </div>
                <div class="text-left">
                    <p class="text-[10px] font-mono font-bold text-slate-500 uppercase tracking-widest">Active Trusted Issuer</p>
                    <code id="issuer-did-display" class="text-xs text-emerald-400 font-mono">did:web:...</code>
                </div>
            </div>
        </div>

        <!-- Bento Grid Visualization Area -->
        <div id="marketing-bento" class="grid grid-cols-1 lg:grid-cols-12 gap-6 w-full mb-12 relative z-10">
            <!-- Code Block (Spans 8 columns) -->
            <div class="lg:col-span-8 glass-card rounded-2xl p-6 flex flex-col shadow-sm relative overflow-hidden">
                <div class="flex items-center justify-between mb-4 border-b border-slate-100 pb-3">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-emerald-500 text-sm">integration_instructions</span>
                        <span class="font-mono text-xs text-slate-500">credential_issuance_spec.json</span>
                    </div>
                    <div class="flex gap-1.5">
                        <span class="w-2.5 h-2.5 rounded-full bg-slate-200" />
                        <span class="w-2.5 h-2.5 rounded-full bg-slate-200" />
                        <span class="w-2.5 h-2.5 rounded-full bg-slate-200" />
                    </div>
                </div>
                <div class="code-block rounded-xl p-4 font-mono text-xs text-slate-600 leading-relaxed overflow-x-auto custom-scrollbar border border-slate-100">
                    <pre class="text-slate-600"><code><span class="text-slate-800">&#123;</span>
  <span class="text-amber-800">"@context"</span>: [
    <span class="text-emerald-700">"https://www.w3.org/2018/credentials/v1"</span>,
    <span class="text-emerald-700">"https://w3id.org/security/suites/jws-2020/v1"</span>
  ],
  <span class="text-amber-800">"type"</span>: [<span class="text-emerald-700">"VerifiableCredential"</span>, <span class="text-emerald-700">"UniversityDegreeCredential"</span>],
  <span class="text-amber-800">"issuer"</span>: <span class="text-emerald-700">"did:web:vericred.dev"</span>,
  <span class="text-amber-800">"credentialSubject"</span>: &#123;
    <span class="text-amber-800">"id"</span>: <span class="text-emerald-700">"did:key:z6MkuSccD1L..."</span>,
    <span class="text-amber-800">"familyName"</span>: <span class="text-emerald-700">"Mustermann"</span>,
    <span class="text-amber-800">"givenName"</span>: <span class="text-emerald-700">"Max"</span>,
    <span class="text-amber-800">"degree"</span>: <span class="text-emerald-700">"Bachelor of Science (Computer Science)"</span>,
    <span class="text-amber-800">"gpa"</span>: <span class="text-emerald-700">"1.3"</span>
  &#125;
<span class="text-slate-800">&#125;</span></code></pre>
                </div>
            </div>

            <!-- Side Value Props (Spans 4 columns) -->
            <div class="lg:col-span-4 flex flex-col gap-6">
                <!-- Prop 1 -->
                <div class="glass-card rounded-2xl p-6 flex flex-col justify-between flex-1">
                    <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/15 flex items-center justify-center text-emerald-600 mb-4">
                        <span class="material-symbols-outlined text-xl">language</span>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 mb-1.5">did:web Native</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">
                            Verankern Sie Ihre Identität direkt auf Ihrer Domain. Keine Blockchain-Gebühren.
                        </p>
                    </div>
                </div>

                <!-- Prop 2 -->
                <div class="glass-card rounded-2xl p-6 flex flex-col justify-between flex-1">
                    <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/15 flex items-center justify-center text-purple-600 mb-4">
                        <span class="material-symbols-outlined text-xl">hub</span>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 mb-1.5">miTch Ready</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">
                            Vollständig kompatibel mit europäischen Wallet-Spezifikationen.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Features Grid -->
        <section id="marketing-features" class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full mt-12 mb-20 relative z-10">
            <div class="flex flex-col gap-3">
                <div class="w-12 h-12 rounded-2xl bg-white shadow-sm flex items-center justify-center text-emerald-500 border border-slate-100">
                    <span class="material-symbols-outlined">security</span>
                </div>
                <h4 class="text-lg font-bold text-slate-900">SD-JWT Privacy</h4>
                <p class="text-slate-500 text-sm leading-relaxed">Nutzen Sie Selective Disclosure, um nur notwendige Daten freizugeben.</p>
            </div>
            <div class="flex flex-col gap-3">
                <div class="w-12 h-12 rounded-2xl bg-white shadow-sm flex items-center justify-center text-blue-500 border border-slate-100">
                    <span class="material-symbols-outlined">sync_alt</span>
                </div>
                <h4 class="text-lg font-bold text-slate-900">Echtzeit-Revocation</h4>
                <p class="text-slate-500 text-sm leading-relaxed">StatusList2021 Integration erlaubt den sofortigen Widerruf.</p>
            </div>
            <div class="flex flex-col gap-3">
                <div class="w-12 h-12 rounded-2xl bg-white shadow-sm flex items-center justify-center text-orange-500 border border-slate-100">
                    <span class="material-symbols-outlined">cable</span>
                </div>
                <h4 class="text-lg font-bold text-slate-900">SQL & REST Connectors</h4>
                <p class="text-slate-500 text-sm leading-relaxed">Mappen Sie Ihre bestehenden Datenbanken direkt.</p>
            </div>
        </section>

        <!-- Live Demo / CTA -->
        <div id="marketing-cta" class="w-full bg-emerald-900 rounded-[2.5rem] p-12 text-center relative overflow-hidden mb-20">
            <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#fff 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
            <div class="relative z-10">
                <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6">Bereit für die Zukunft der Identität?</h2>
                <p class="text-emerald-100 text-lg mb-10 max-w-2xl mx-auto">VeriCred ist Open-Source und für den produktiven Einsatz konzipiert.</p>
                <div class="flex flex-wrap justify-center gap-4">
                    <a href="/console/setup" class="bg-white text-emerald-900 font-bold px-8 py-4 rounded-2xl hover:bg-emerald-50 transition-all flex items-center gap-2">
                        <span>Setup Wizard starten</span>
                        <span class="material-symbols-outlined">magic_button</span>
                    </a>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-100 bg-white/40 py-10 px-6 mt-auto">
        <div class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto w-full gap-6">
            <div class="flex items-center gap-3">
                <svg width="24" height="24" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="200" height="200" rx="40" fill="#1C1917" />
                    <path d="M60 70L100 140L140 70" stroke="#10B981" stroke-width="20" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M100 140L160 50" stroke="#10B981" stroke-width="20" stroke-linecap="round" stroke-linejoin="round" opacity="0.8" />
                    <circle cx="100" cy="100" r="10" fill="#F8FAFC" />
                </svg>
                <span class="font-bold text-slate-800 text-sm">VeriCred Gateway Platform</span>
            </div>
            <div class="flex gap-6 text-xs font-mono text-slate-500">
                <a href="/dev/navigator" class="hover:text-slate-900 transition-colors">Library</a>
                <a href="/walkthrough.md" target="_blank" class="hover:text-slate-900 transition-colors">Documentation</a>
                <a href="/docs/WALLET_INTEROP_GUIDE.md" target="_blank" class="hover:text-slate-900 transition-colors">Interop Guide</a>
                <a href="https://github.com/askmi-dev/vericred" target="_blank" class="hover:text-slate-900 transition-colors">GitHub</a>
            </div>
            <span class="text-xs font-mono text-slate-400">© 2026 VeriCred open source gateway platform. Built with passion for privacy.</span>
        </div>
    </footer>

    <script is:inline>
        // White-Label Hydration
        fetch('/api/info')
            .then(res => res.json())
            .then(data => {
                if (data.isConfigured) {
                    // Update Page for End-Users (Holders)
                    document.title = `${data.issuerName} | Digital Credential Portal`;
                    
                    const brandEl = document.getElementById('nav-brand-name');
                    if (brandEl) brandEl.textContent = data.issuerName;
                    
                    const ctaTextEl = document.getElementById('nav-cta-text');
                    if (ctaTextEl) ctaTextEl.textContent = 'Admin Console';
                    
                    const badgeEl = document.getElementById('hero-badge');
                    if (badgeEl) badgeEl.innerHTML = `<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> OPERATIONAL TRUST GATEWAY`;
                    
                    const titleEl = document.getElementById('hero-title');
                    if (titleEl) titleEl.textContent = `${data.issuerName} Digital Credentials`;
                    
                    const descEl = document.getElementById('hero-desc');
                    if (descEl) descEl.textContent = `Erhalten und verifizieren Sie Ihre offiziellen digitalen Nachweise von ${data.issuerName}. Sicher, datenschutzfreundlich und EU-Wallet kompatibel.`;
                    
                    // Update CTAs for Holder/Verifier Focus
                    const ctaPrimary = document.getElementById('cta-primary');
                    if (ctaPrimary) {
                        ctaPrimary.href = '/dev/packstation'; 
                        ctaPrimary.innerHTML = `<span>Nachweis beantragen</span><span class="material-symbols-outlined text-lg">badge</span>`;
                    }
                    
                    const ctaSecondary = document.getElementById('cta-secondary');
                    if (ctaSecondary) {
                        ctaSecondary.href = '/dev/presentation';
                        ctaSecondary.innerHTML = `<span>Nachweis prüfen</span><span class="material-symbols-outlined text-lg">fact_check</span>`;
                    }
                    
                    // Show Issuer Card
                    const infoCard = document.getElementById('issuer-info-card');
                    if (infoCard) {
                        infoCard.classList.remove('hidden');
                        document.getElementById('issuer-did-display').textContent = data.issuerDid;
                    }

                    // Hide Marketing-specific sections
                    ['marketing-bento', 'marketing-features', 'marketing-cta'].forEach(id => {
                        const el = document.getElementById(id);
                        if (el) el.classList.add('hidden');
                    });
                }
            })
            .catch(err => console.error('Landing page hydration failed:', err));
    </script>

</body>
</html>
