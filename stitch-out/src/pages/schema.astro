---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Schema Mapping">
    <!-- Page Header -->
    <div class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight">Schema Mapping Workspace</h2>
        <p class="text-slate-400 text-sm md:text-base mt-1">Bind your connected data source columns to standard W3C Verifiable Credential claim fields with selective disclosure constraints.</p>
    </div>

    <!-- Action & Status Bar -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-slate-900/60 border border-slate-800/80 rounded-2xl p-5 mb-8 backdrop-blur-md gap-4">
        <div class="flex items-center gap-4">
            <div class="flex flex-col">
                <span class="text-[10px] font-mono font-bold text-slate-500 uppercase tracking-wider">Mapping Status</span>
                <div class="flex items-center gap-2 mt-1">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-sm font-semibold text-emerald-400">4 / 6 Required Claims Fully Mapped</span>
                </div>
            </div>
        </div>
        
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <button id="btn-test-mapping" class="w-full sm:w-auto px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-200 hover:text-white rounded-xl border border-slate-700/80 transition-all flex items-center justify-center gap-2 text-xs font-semibold uppercase tracking-wider">
                <span class="material-symbols-outlined text-sm">bug_report</span>
                <span>Test Mapping</span>
            </button>
            <button id="btn-save-schema" class="w-full sm:w-auto px-4 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl transition-all flex items-center justify-center gap-2 text-xs font-semibold uppercase tracking-wider shadow-[0_0_15px_rgba(16,185,129,0.2)] hover:shadow-[0_0_20px_rgba(16,185,129,0.3)]">
                <span class="material-symbols-outlined text-sm">save</span>
                <span>Save Schema</span>
            </button>
        </div>
    </div>

    <!-- Mapping Workspace Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 min-h-[550px] items-stretch">
        <!-- Source Fields (Left) -->
        <div class="lg:col-span-4 bg-slate-900/60 border border-slate-800/80 rounded-2xl flex flex-col overflow-hidden">
            <div class="p-4 border-b border-slate-800 bg-slate-950/40">
                <h3 class="text-sm font-bold text-white tracking-tight flex items-center gap-2">
                    <span class="material-symbols-outlined text-emerald-500 text-base">database</span>
                    <span>Connected Source Schema</span>
                </h3>
                <p class="text-[10px] font-mono text-slate-500 mt-1 uppercase tracking-wider">Table: <span class="text-slate-300">students_records_v2</span></p>
            </div>
            
            <div class="flex-grow p-4 space-y-3 overflow-y-auto custom-scrollbar">
                <!-- Mapped Source 1 -->
                <div class="p-3.5 border border-emerald-500/20 bg-emerald-500/5 hover:border-emerald-500/40 rounded-xl transition-all flex justify-between items-center group relative cursor-grab active:cursor-grabbing">
                    <div>
                        <div class="font-mono text-xs font-semibold text-slate-200">student_id</div>
                        <div class="font-mono text-[9px] text-slate-500 mt-0.5">VARCHAR(50) • PRIMARY KEY</div>
                    </div>
                    <span class="material-symbols-outlined text-emerald-500/60 group-hover:text-emerald-400 text-lg transition-colors">drag_indicator</span>
                    <!-- Connector Dot -->
                    <div class="absolute -right-[6px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-emerald-500 border border-slate-950 z-10"></div>
                </div>

                <!-- Mapped Source 2 -->
                <div class="p-3.5 border border-emerald-500/20 bg-emerald-500/5 hover:border-emerald-500/40 rounded-xl transition-all flex justify-between items-center group relative cursor-grab active:cursor-grabbing">
                    <div>
                        <div class="font-mono text-xs font-semibold text-slate-200">full_name</div>
                        <div class="font-mono text-[9px] text-slate-500 mt-0.5">VARCHAR(100) • INDEXED</div>
                    </div>
                    <span class="material-symbols-outlined text-emerald-500/60 group-hover:text-emerald-400 text-lg transition-colors">drag_indicator</span>
                    <div class="absolute -right-[6px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-emerald-500 border border-slate-950 z-10"></div>
                </div>

                <!-- Unmapped Source 3 -->
                <div class="p-3.5 border border-slate-800 bg-slate-950/40 hover:border-slate-700 rounded-xl transition-all flex justify-between items-center group relative cursor-grab active:cursor-grabbing">
                    <div>
                        <div class="font-mono text-xs font-semibold text-slate-400 group-hover:text-slate-300">grad_date</div>
                        <div class="font-mono text-[9px] text-slate-600 mt-0.5">DATE</div>
                    </div>
                    <span class="material-symbols-outlined text-slate-600 group-hover:text-slate-400 text-lg transition-colors">drag_indicator</span>
                </div>

                <!-- Unmapped Source 4 -->
                <div class="p-3.5 border border-slate-800 bg-slate-950/40 hover:border-slate-700 rounded-xl transition-all flex justify-between items-center group relative cursor-grab active:cursor-grabbing">
                    <div>
                        <div class="font-mono text-xs font-semibold text-slate-400 group-hover:text-slate-300">degree_name</div>
                        <div class="font-mono text-[9px] text-slate-600 mt-0.5">VARCHAR(255)</div>
                    </div>
                    <span class="material-symbols-outlined text-slate-600 group-hover:text-slate-400 text-lg transition-colors">drag_indicator</span>
                </div>

                <!-- Unmapped Source 5 -->
                <div class="p-3.5 border border-slate-800 bg-slate-950/40 hover:border-slate-700 rounded-xl transition-all flex justify-between items-center group relative cursor-grab active:cursor-grabbing">
                    <div>
                        <div class="font-mono text-xs font-semibold text-slate-400 group-hover:text-slate-300">honors_flag</div>
                        <div class="font-mono text-[9px] text-slate-600 mt-0.5">BOOLEAN</div>
                    </div>
                    <span class="material-symbols-outlined text-slate-600 group-hover:text-slate-400 text-lg transition-colors">drag_indicator</span>
                </div>
            </div>
        </div>

        <!-- Middle Connecting Lines SVG Canvas (Large Screens only) -->
        <div class="hidden lg:block lg:col-span-1 relative pointer-events-none">
            <svg class="absolute inset-0 w-full h-full" style="z-index: 10;">
                <!-- Line 1: student_id -> id -->
                <path d="M 0 74 C 40 74, 10 134, 100% 134" fill="none" stroke="#10B981" stroke-width="2.5" class="drop-shadow-[0_0_4px_rgba(16,185,129,0.4)] opacity-80" />
                <!-- Line 2: full_name -> name -->
                <path d="M 0 142 C 40 142, 10 215, 100% 215" fill="none" stroke="#10B981" stroke-width="2.5" class="drop-shadow-[0_0_4px_rgba(16,185,129,0.4)] opacity-80" />
            </svg>
        </div>

        <!-- Target claims (Middle-Right) -->
        <div class="lg:col-span-4 bg-slate-900/60 border border-slate-800/80 rounded-2xl flex flex-col overflow-hidden">
            <div class="p-4 border-b border-slate-800 bg-slate-950/40">
                <h3 class="text-sm font-bold text-white tracking-tight flex items-center gap-2">
                    <span class="material-symbols-outlined text-emerald-400 text-base">assignment_turned_in</span>
                    <span>Target VC claims Schema</span>
                </h3>
                <p class="text-[10px] font-mono text-slate-500 mt-1 uppercase tracking-wider">Format: <span class="text-emerald-500">SD-JWT-VC (W3C UniversityDegree)</span></p>
            </div>
            
            <div class="flex-grow p-4 space-y-4 overflow-y-auto custom-scrollbar">
                <!-- Group Label Required -->
                <div class="text-[9px] font-mono font-bold text-slate-500 uppercase tracking-widest pl-1">Required Claims</div>
                
                <!-- Target 1 (Mapped ID) -->
                <div class="p-3 bg-emerald-500/5 border border-emerald-500/20 rounded-xl relative">
                    <div class="absolute -left-[6px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-emerald-500 border border-slate-950 z-10"></div>
                    <div class="flex justify-between items-start">
                        <div>
                            <div class="font-mono text-xs font-bold text-white">credentialSubject.id</div>
                            <div class="font-mono text-[9px] text-slate-400 mt-0.5">Holder Pairwise Pseudonym</div>
                        </div>
                        <span class="material-symbols-outlined text-emerald-400 text-base">check_circle</span>
                    </div>
                    <div class="mt-2.5 text-[10px] font-mono bg-slate-950 border border-emerald-500/20 px-2 py-1 rounded text-emerald-400 flex items-center gap-1.5 w-fit">
                        <span class="material-symbols-outlined text-xs">link</span>
                        <span>student_id</span>
                    </div>
                </div>

                <!-- Target 2 (Mapped Name) -->
                <div class="p-3 bg-emerald-500/5 border border-emerald-500/20 rounded-xl relative">
                    <div class="absolute -left-[6px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-emerald-500 border border-slate-950 z-10"></div>
                    <div class="flex justify-between items-start">
                        <div>
                            <div class="font-mono text-xs font-bold text-white">credentialSubject.name</div>
                            <div class="font-mono text-[9px] text-slate-400 mt-0.5">Holder Full Name</div>
                        </div>
                        <span class="material-symbols-outlined text-emerald-400 text-base">check_circle</span>
                    </div>
                    <div class="mt-2.5 text-[10px] font-mono bg-slate-950 border border-emerald-500/20 px-2 py-1 rounded text-emerald-400 flex items-center gap-1.5 w-fit">
                        <span class="material-symbols-outlined text-xs">link</span>
                        <span>full_name</span>
                    </div>
                </div>

                <!-- Target 3 (Unmapped Required Degree) -->
                <div class="p-3 bg-red-500/5 border border-red-500/20 border-dashed rounded-xl relative group hover:border-red-500/40 transition-colors">
                    <div class="absolute -left-[6px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full border border-red-500/40 bg-slate-950 z-10"></div>
                    <div class="flex justify-between items-start">
                        <div>
                            <div class="font-mono text-xs font-bold text-red-400 flex items-center gap-1">
                                <span>credentialSubject.degree</span>
                                <span class="text-red-500 font-bold">*</span>
                            </div>
                            <div class="font-mono text-[9px] text-red-400/60 mt-0.5">Degree Title (e.g. B.Sc)</div>
                        </div>
                        <span class="material-symbols-outlined text-red-400/80 text-base">error_outline</span>
                    </div>
                    <div class="mt-2.5 text-[10px] font-mono text-red-400/60 italic flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs">arrow_downward</span>
                        <span>Drag source column here</span>
                    </div>
                </div>

                <!-- Group Label Optional -->
                <div class="text-[9px] font-mono font-bold text-slate-500 uppercase tracking-widest pl-1 pt-2">Optional Claims</div>

                <!-- Target 4 (Optional Date) -->
                <div class="p-3 bg-slate-950/40 border border-slate-800/80 border-dashed rounded-xl relative group hover:border-slate-700 transition-colors">
                    <div class="absolute -left-[6px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full border border-slate-800 bg-slate-950 z-10"></div>
                    <div class="flex justify-between items-start">
                        <div>
                            <div class="font-mono text-xs font-bold text-slate-400 group-hover:text-slate-300">issuanceDate</div>
                            <div class="font-mono text-[9px] text-slate-500 mt-0.5">DateTime</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Live Preview (Right Panel) -->
        <div class="lg:col-span-3 bg-slate-900/60 border border-slate-800/80 rounded-2xl flex flex-col overflow-hidden">
            <div class="p-4 border-b border-slate-800 bg-slate-950/40 flex justify-between items-center">
                <h3 class="text-sm font-bold text-white tracking-tight flex items-center gap-2">
                    <span class="material-symbols-outlined text-purple-400 text-base">code</span>
                    <span>Live SD-JWT Preview</span>
                </h3>
                <button id="btn-copy-preview" class="text-slate-400 hover:text-white transition-colors p-1" title="Copy JSON payload">
                    <span class="material-symbols-outlined text-lg">content_copy</span>
                </button>
            </div>
            
            <div class="flex-grow p-4 bg-slate-950/80 overflow-y-auto overflow-x-auto font-mono text-[11px] leading-relaxed text-slate-300 custom-scrollbar max-h-[420px]">
<pre><code class="text-slate-400">&#123;
  <span class="text-emerald-400">"issuer"</span>: "did:web:vericred.dev",
  <span class="text-emerald-400">"issuanceDate"</span>: "2026-06-04T03:27:00Z",
  <span class="text-emerald-400">"credentialSubject"</span>: &#123;
    <span class="text-emerald-400">"id"</span>: "did:key:z6MkuSccD1L...",
    <span class="text-emerald-400">"name"</span>: "Max Mustermann",
    <span class="text-emerald-400">"degree"</span>: <span class="text-red-400">null</span>
  &#125;
&#125;</code></pre>
            </div>

            <!-- Preview Bottom Status Bar -->
            <div class="p-3 bg-slate-950 border-t border-slate-800/80 flex flex-col sm:flex-row justify-between items-start sm:items-center text-[10px] font-mono gap-1">
                <span class="flex items-center gap-1 text-red-400">
                    <span class="material-symbols-outlined text-xs">warning</span>
                    <span>Validation Error: Missing 'degree'</span>
                </span>
                <span class="text-slate-500 font-semibold tracking-wider">FORMAT: SD-JWT</span>
            </div>
        </div>
    </div>

    <!-- Client Handlers -->
    <script is:inline>
        const testBtn = document.getElementById('btn-test-mapping');
        const saveBtn = document.getElementById('btn-save-schema');
        const copyPreviewBtn = document.getElementById('btn-copy-preview');

        if (testBtn) {
            testBtn.addEventListener('click', () => {
                if (window.triggerToast) {
                    window.triggerToast('Compiling schema and performing dry-run test... All checks passed!');
                }
            });
        }

        if (saveBtn) {
            saveBtn.addEventListener('click', () => {
                if (window.triggerToast) {
                    window.triggerToast('Schema mappings successfully updated and saved to vericred.config.json!');
                }
            });
        }

        if (copyPreviewBtn) {
            copyPreviewBtn.addEventListener('click', () => {
                const previewJson = `{
  "issuer": "did:web:vericred.dev",
  "issuanceDate": "2026-06-04T03:27:00Z",
  "credentialSubject": {
    "id": "did:key:z6MkuSccD1L...",
    "name": "Max Mustermann",
    "degree": null
  }
}`;
                navigator.clipboard.writeText(previewJson).then(() => {
                    if (window.triggerToast) {
                        window.triggerToast('JSON preview payload copied to clipboard!');
                    }
                });
            });
        }
    </script>
</AdminLayout>
