{
  "issuer": {
    "name": "VeriCred Issuer",
    "url": "http://localhost:3100",
    "did": "did:web:localhost%3A3100"
  },
  "credential": {
    "type": "AgeCredential",
    "expiresInDays": 365
  },
  "dataSource": {
    "type": "json",
    "path": "./data/holders.json"
  },
  "fieldMappings": {
    "givenName": "firstName",
    "familyName": "lastName",
    "email": "email",
    "dateOfBirth": "dateOfBirth"
  }
}