{
  "issuer": {
    "name": "the Thing",
    "url": "https://thatthing.de",
    "did": "did:web:thatthing.de"
  },
  "credential": {
    "type": "AgeCredential",
    "expiresInDays": 365
  },
  "dataSource": {
    "type": "json",
    "path": "./data/holders.json"
  },
  "fieldMappings": {
    "givenName": "firstName",
    "familyName": "lastName",
    "email": "email",
    "dateOfBirth": "dateOfBirth"
  }
}